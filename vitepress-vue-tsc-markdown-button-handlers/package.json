{
  "name": "vitepress-vue-tsc-markdown-button-handlers",
  "private": true,
  "type": "module",
  "scripts": {
    "ci:repro": "node ./scripts/ci-repro.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "typecheck": "pnpm run typecheck:vue-tsc",
    "typecheck:golar": "golar tsc -b tsconfig.json",
