  },
  "dependencies": {
    "compat-finder": "^2.1.0",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@golar/vue": "^0.1.8",
    "golar": "^0.1.8",
    "typescript": "^6.0.3",
    "vitepress": "2.0.0-alpha.17",
    "vue-tsc": "^3.3.5",
    "vue-tsgo": "^0.2.2"
  }
}
